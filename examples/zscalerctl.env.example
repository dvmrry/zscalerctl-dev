# Copy this to a local untracked file and keep that file owner-readable only.
# Example:
#   cp examples/zscalerctl.env.example .env
#   chmod 600 .env

ZSCALERCTL_PROFILE=default
ZSCALERCTL_AUTH_MODE=oneapi
ZSCALERCTL_VANITY_DOMAIN=
ZSCALERCTL_CLOUD=PRODUCTION
ZSCALERCTL_CLIENT_ID=

# Prefer a local owner-only file for the client secret.
ZSCALERCTL_CLIENT_SECRET_FILE=

# Inline client-secret variables are intentionally omitted from this example.
# Keep checked-in examples value-free.

# ZPA resources only: the customer id is required only when reading ZPA
# resources; the microtenant id is optional.
#ZSCALERCTL_ZPA_CUSTOMER_ID=
#ZSCALERCTL_ZPA_MICROTENANT_ID=

# ZIA legacy auth is explicit and does not read raw SDK ZIA_* env names.
# Set ZSCALERCTL_AUTH_MODE=zia-legacy to use these values.
ZSCALERCTL_ZIA_USERNAME=
ZSCALERCTL_ZIA_PASSWORD_FILE=
ZSCALERCTL_ZIA_API_KEY_FILE=
ZSCALERCTL_ZIA_CLOUD=

# Optional proxy support. Default direct transport ignores ambient proxy env.
# Set ZSCALERCTL_PROXY_FROM_ENV=true to honor HTTPS_PROXY/HTTP_PROXY/NO_PROXY,
# or set ZSCALERCTL_PROXY_URL to use a dedicated proxy URL.
ZSCALERCTL_PROXY_FROM_ENV=false
ZSCALERCTL_PROXY_URL=

ZSCALERCTL_REDACTION=standard
ZSCALERCTL_NO_CACHE=false
