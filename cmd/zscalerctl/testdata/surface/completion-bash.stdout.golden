services ztw/public-cloud-accounts ztw/public-cloud-info ztw/traffic-dns-rules ztw/traffic-log-rules ztw/workload-groups ztw/zpa-application-segments" -- "$cur") ); return ;;
    completion) COMPREPLY=( $(compgen -W "bash zsh fish powershell" -- "$cur") ); return ;;
    auth) COMPREPLY=( $(compgen -W "status" -- "$cur") ); return ;;
    config) COMPREPLY=( $(compgen -W "show init" -- "$cur") ); return ;;
    schema) COMPREPLY=( $(compgen -W "list" -- "$cur") ); return ;;
    dump) COMPREPLY=( $(compgen -W "--continue-on-error --force --out --products --resources" -- "$cur") ); return ;;
    diff) COMPREPLY=( $(compgen -W "--allow-partial --detail --fail-on-drift --ignore-operational --products --resources" -- "$cur") ); return ;;
    zia) COMPREPLY=( $(compgen -W "activation-status admin-roles admin-users advanced-settings advanced-threat-settings alert-subscriptions application-service-groups application-services atp-malware-inspection atp-malware-policy atp-malware-protocols atp-malware-settings auth-exempted-urls auth-settings bandwidth-classes bandwidth-control-rules browser-control-settings browser-isolation-profiles c2c-incident-receivers casb-dlp-rules casb-email-labels casb-malware-rules casb-tenants casb-tombstone-templates cloud-app-control cloud-app-instances cloud-application-policy cloud-application-ssl-policy custom-file-types dc-exclusions dedicated-ip-gateways departments device-groups devices dlp-dictionaries dlp-edm-schemas dlp-edm-schemas-lite dlp-engines dlp-icap-servers dlp-idm-profile-lite dlp-idm-profiles dlp-incident-receiver-servers dlp-notification-templates dlp-web-rules dns-gateways domain-profiles email-profiles end-user-notification-settings eusa-status file-type-rules firewall-dns-rules firewall-filtering-rules forwarding-rules ftp-control-policy gre-tunnels groups intermediate-ca-certificates ip-destination-groups ip-source-groups ips-policies ips-signature-rules ipv6-config ipv6-dns64-prefixes ipv6-nat64-prefixes location-groups locations malicious-urls mobile-threat-settings nat-control-rules network-application-groups network-applications network-service-groups network-services nss-feeds nss-servers org-information pac-files proxies proxy-gateways remote-assistance risk-profiles rule-labels sandbox-rules sandbox-settings security-exceptions ssl-inspection-rules static-ips sub-clouds sublocations supported-browser-versions tenancy-restriction-profiles time-intervals time-windows url-allow-list url-categories url-deny-list url-filtering-rules url-lookup users vzen-clusters vzen-nodes workload-groups zpa-gateways" -- "$cur") ); return ;;
    zpa) COMPREPLY=( $(compgen -W "app-connector-groups app-connectors app-servers application-segments branch-connectors browser-access c2c-ip-ranges cbi-zpa-profiles client-types cloud-connector-groups cloud-connectors config-overrides inspection-app-segments isolation-profiles machine-groups microtenants platforms posture-profiles pra-app-segments segment-groups server-groups service-edge-groups service-edges trusted-networks user-portal-aups user-portal-links user-portals version-profiles" -- "$cur") ); return ;;
    ztw) COMPREPLY=( $(compgen -W "account-groups activation-status admin-roles admin-users dns-gateways ec-groups forwarding-gateways forwarding-rules ip-destination-groups ip-groups ip-source-groups location-templates locations network-service-groups network-services public-cloud-accounts public-cloud-info traffic-dns-rules traffic-log-rules workload-groups zpa-application-segments" -- "$cur") ); return ;;
    zcc) COMPREPLY=( $(compgen -W "admin-roles application-profiles company-info custom-ip-apps devices fail-open-policy forwarding-profiles predefined-ip-apps process-based-apps trusted-networks web-app-services" -- "$cur") ); return ;;
    zidentity) COMPREPLY=( $(compgen -W "groups resource-servers users" -- "$cur") ); return ;;
    account-groups|activation-status|admin-roles|admin-users|advanced-settings|advanced-threat-settings|alert-subscriptions|app-connector-groups|app-connectors|app-servers|application-profiles|application-segments|application-service-groups|application-services|atp-malware-inspection|atp-malware-policy|atp-malware-protocols|atp-malware-settings|auth-exempted-urls|auth-settings|bandwidth-classes|bandwidth-control-rules|branch-connectors|browser-access|browser-control-settings|browser-isolation-profiles|c2c-incident-receivers|c2c-ip-ranges|casb-dlp-rules|casb-email-labels|casb-malware-rules|casb-tenants|casb-tombstone-templates|cbi-zpa-profiles|client-types|cloud-app-control|cloud-app-instances|cloud-application-policy|cloud-application-ssl-policy|cloud-connector-groups|cloud-connectors|company-info|config-overrides|custom-file-types|custom-ip-apps|dc-exclusions|dedicated-ip-gateways|departments|device-groups|devices|dlp-dictionaries|dlp-edm-schemas|dlp-edm-schemas-lite|dlp-engines|dlp-icap-servers|dlp-idm-profile-lite|dlp-idm-profiles|dlp-incident-receiver-servers|dlp-notification-templates|dlp-web-rules|dns-gateways|domain-profiles|ec-groups|email-profiles|end-user-notification-settings|eusa-status|fail-open-policy|file-type-rules|firewall-dns-rules|firewall-filtering-rules|forwarding-gateways|forwarding-profiles|forwarding-rules|ftp-control-policy|gre-tunnels|groups|inspection-app-segments|intermediate-ca-certificates|ip-destination-groups|ip-groups|ip-source-groups|ips-policies|ips-signature-rules|ipv6-config|ipv6-dns64-prefixes|ipv6-nat64-prefixes|isolation-profiles|location-groups|location-templates|locations|machine-groups|malicious-urls|microtenants|mobile-threat-settings|nat-control-rules|network-application-groups|network-applications|network-service-groups|network-services|nss-feeds|nss-servers|org-information|pac-files|platforms|posture-profiles|pra-app-segments|predefined-ip-apps|process-based-apps|proxies|proxy-gateways|public-cloud-accounts|public-cloud-info|remote-assistance|resource-servers|risk-profiles|rule-labels|sandbox-rules|sandbox-settings|security-exceptions|segment-groups|server-groups|service-edge-groups|service-edges|ssl-inspection-rules|static-ips|sub-clouds|sublocations|supported-browser-versions|tenancy-restriction-profiles|time-intervals|time-windows|traffic-dns-rules|traffic-log-rules|trusted-networks|url-allow-list|url-categories|url-deny-list|url-filtering-rules|user-portal-aups|user-portal-links|user-portals|users|version-profiles|vzen-clusters|vzen-nodes|web-app-services|workload-groups|zpa-application-segments|zpa-gateways) COMPREPLY=( $(compgen -W "list get show" -- "$cur") ); return ;;
  esac

  COMPREPLY=( $(compgen -W "--color --config --fields --filter --format --log-level --no-cache --no-color --output --profile --redaction --search --timeout auth completion config diff doctor dump help schema version zcc zia zidentity zpa ztw" -- "$cur") )
}
complete -F _zscalerctl zscalerctl
