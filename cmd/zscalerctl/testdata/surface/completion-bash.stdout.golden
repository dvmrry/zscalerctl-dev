# bash completion for zscalerctl
_zscalerctl()
{
  local cur prev
  COMPREPLY=()
  cur="${COMP_WORDS[COMP_CWORD]}"
  prev="${COMP_WORDS[COMP_CWORD-1]}"

  case "$prev" in
    --format) COMPREPLY=( $(compgen -W "auto table json ndjson pretty" -- "$cur") ); return ;;
    --redaction) COMPREPLY=( $(compgen -W "standard share paranoid" -- "$cur") ); return ;;
    --color) COMPREPLY=( $(compgen -W "auto always never" -- "$cur") ); return ;;
    --log-level) COMPREPLY=( $(compgen -W "off error warn info debug" -- "$cur") ); return ;;
    --products) COMPREPLY=( $(compgen -W "zia zpa ztw zcc zidentity zia,zpa,ztw,zcc,zidentity" -- "$cur") ); return ;;
    --resources) COMPREPLY=( $(compgen -W "account-groups activation-status admin-roles admin-users advanced-settings advanced-threat-settings alert-subscriptions app-connector-groups app-connectors app-servers application-profiles application-segments application-service-groups application-services atp-malware-inspection atp-malware-policy atp-malware-protocols atp-malware-settings auth-exempted-urls auth-settings bandwidth-classes bandwidth-control-rules branch-connectors browser-access browser-control-settings browser-isolation-profiles c2c-incident-receivers c2c-ip-ranges casb-dlp-rules casb-email-labels casb-malware-rules casb-tenants casb-tombstone-templates cbi-zpa-profiles client-types cloud-app-control cloud-app-instances cloud-application-policy cloud-application-ssl-policy cloud-connector-groups cloud-connectors company-info config-overrides custom-file-types custom-ip-apps dc-exclusions dedicated-ip-gateways departments device-groups devices dlp-dictionaries dlp-edm-schemas dlp-edm-schemas-lite dlp-engines dlp-icap-servers dlp-idm-profile-lite dlp-idm-profiles dlp-incident-receiver-servers dlp-notification-templates dlp-web-rules dns-gateways domain-profiles ec-groups email-profiles end-user-notification-settings eusa-status fail-open-policy file-type-rules firewall-dns-rules firewall-filtering-rules forwarding-gateways forwarding-profiles forwarding-rules ftp-control-policy gre-tunnels groups inspection-app-segments intermediate-ca-certificates ip-destination-groups ip-groups ip-source-groups ips-policies ips-signature-rules ipv6-config ipv6-dns64-prefixes ipv6-nat64-prefixes isolation-profiles location-groups location-templates locations machine-groups malicious-urls microtenants mobile-threat-settings nat-control-rules network-application-groups network-applications network-service-groups network-services nss-feeds nss-servers org-information pac-files platforms posture-profiles pra-app-segments predefined-ip-apps process-based-apps proxies proxy-gate