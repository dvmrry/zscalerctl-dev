{
  "$schema": "https://raw.githubusercontent.com/dvmrry/zscalerctl/main/docs/schema/introspect.schema.json",
  "introspect_version": "1",
  "cli_version": "<VERSION>",
  "read_only": true,
  "global_flags": [
    {
      "name": "color",
      "type": "string",
      "default": "auto",
      "usage": "color output: auto, always, never",
      "enum": [
        "auto",
        "always",
        "never"
      ]
    },
    {
      "name": "config",
      "type": "string",
      "usage": "config file path"
    },
    {
      "name": "fields",
      "type": "string",
      "usage": "comma-separated output fields to keep (narrows the sanitized output)"
    },
    {
      "name": "filter",
      "type": "stringArray",
      "usage": "narrow list results: key=value (exact) or key~value (substring); repeatable, all must match"
    },
    {
      "name": "format",
      "type": "string",
      "default": "auto",
      "usage": "output format: auto, table, json, ndjson, pretty",
      "enum": [
        "auto",
        "table",
        "json",
        "ndjson",
        "pretty"
      ]
    },
    {
      "name": "log-level",
      "type": "string",
      "default": "off",
      "usage": "diagnostic logging to stderr: off, error, warn, info, debug",
      "enum": [
        "off",
        "error",
        "warn",
        "info",
        "debug"
      ]
    },
    {
      "name": "no-cache",
      "type": "bool",
      "default": "false",
      "usage": "bypass API cache where supported"
    },
    {
      "name": "no-color",
      "type": "bool",
      "default": "false",
      "usage": "disable color output"
    },
    {
      "name": "output",
      "type": "string",
      "usage": "output path"
    },
    {
      "name": "profile",
      "type": "string",
      "usage": "profile name"
    },
    {
      "name": "redaction",
      "type": "string",
      "usage": "redaction mode: standard, share, paranoid",
      "enum": [
        "standard",
        "share",
        "paranoid"
      ]
    },
    {
      "name": "search",
      "type": "string",
      "usage": "narrow list results to records whose rendered values contain term (case-insensitive)"
    },
    {
      "name": "timeout",
      "type": "duration",
      "default": "30s",
      "usage": "request timeout"
    }
  ],
  "commands": [
